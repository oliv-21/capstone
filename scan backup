  <script>
    
    const statusDiv = document.getElementById('status');
    const logEntriesDiv = document.getElementById('log-entries');

    

    async function sendScanData(qrText) {
      const now = new Date();
      const dateStr = now.toISOString().split('T')[0];
      const timeStr = now.toLocaleTimeString();

      const markType = document.querySelector('input[name="markType"]:checked').value;

      const payload = {
        guardian_qr_id: qrText,
        date: dateStr,
        arrival_time: timeStr,
        status: 'Present'
      };

      statusDiv.textContent = 'Sending data...';
      console.log('[sendScanData] Sending payload:', payload);

      // Choose URL based on radio button value
      let url = '';
      if (markType === 'arrival') {
        url = 'attendance/mark-arrivalqr';
      } else if (markType === 'pickup') {
        url = 'attendance/mark-pickupqr';
      }

      console.log(`[sendScanData] Fetching: POST ${url}`);

      try {
        const res = await fetch(url, {
          method: 'post',
          headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
          },
          body: JSON.stringify(payload)
        });

        console.log('[sendScanData] Response status:', res.status);

        let data;
        try {
          data = await res.json();
          console.log('[sendScanData] Response JSON:', data);
        } catch(jsonErr) {
          console.error('[sendScanData] Failed to parse JSON:', jsonErr);
         
          alert('❌ Error: Invalid server response');
          return;
        }

        if (res.ok && data.success) {
         
          alert(`✅ ${markType.charAt(0).toUpperCase() + markType.slice(1)} marked successfully!`);
          
        } else {
          statusDiv.textContent = '❌ Failed: ' + (data.message || 'Unknown error');
          console.warn('[sendScanData] Mark failed:', data);
          alert('❌ Failed: ' + (data.message || 'Unknown error'));
        }
      } catch (err) {
        
        console.error('[sendScanData] Fetch error:', err);
        alert('❌ Error: ' + err.message);
      }
    }

    const html5QrCode = new Html5Qrcode("reader");

    const qrCodeSuccessCallback = async (decodedText) => {
      console.log('[qrCodeSuccessCallback] QR Code detected:', decodedText);
      await html5QrCode.pause();
      statusDiv.textContent = 'Processing...';
      console.log('[qrCodeSuccessCallback] Scanner paused');

      await sendScanData(decodedText);

      setTimeout(async () => {
        try {
          await html5QrCode.resume();
          statusDiv.textContent = 'Ready to scan...';
          console.log('[qrCodeSuccessCallback] Scanner resumed');
        } catch (resumeErr) {
          statusDiv.textContent = '⚠️ Failed to resume scanner.';
          console.error('[qrCodeSuccessCallback] Resume error:', resumeErr);
        }
      }, 3000);
    };

    const config = { fps: 10, qrbox: 250 };
    console.log('[INIT] Starting html5QrCode with config:', config);

    html5QrCode.start(
      { facingMode: "environment" },
      config,
      qrCodeSuccessCallback
    ).then(() => {
      statusDiv.textContent = '📸 Scanner started. Point camera at QR code.';
      console.log('[INIT] Scanner started');
    }).catch(err => {
      statusDiv.textContent = '❌ Unable to start scanner: ' + err;
      console.error('[INIT] Unable to start scanner:', err);
    });
  </script>


