    public function markArrivalqrcode()
    {
        
        header('Access-Control-Allow-Origin: *');
        header('Access-Control-Allow-Headers: Content-Type, X-Requested-With');
        header('Access-Control-Allow-Methods: POST, OPTIONS');

        if ($_SERVER['REQUEST_METHOD'] === 'OPTIONS') {
            // Handle preflight
            exit(0);
        }

        if (!$this->request->isAJAX() || !$this->request->is('post')) {
            return $this->failForbidden('Invalid request');
        }

        $data = $this->request->getJSON(true);

        if (empty($data['guardian_qr_id']) || empty($data['date']) || empty($data['arrival_time'])) {
            return $this->failValidationErrors('Missing required fields');
        }

        $qrCode = $data['guardian_qr_id'];

        // Remove "Guardian ID: " prefix if it exists (trim spaces too)
        $qrCode = trim(str_replace('Guardian ID:', '', $qrCode));

        if (substr($qrCode, -4) !== '.png') {
            $qrCode .= '.png';
        }

        log_message('debug', 'Processed QR Code: ' . $qrCode);

        // Load Guardian model and find guardian by QR code
        $guardianModel = new \App\Models\GuardianModel();
        $guardian = $guardianModel->getUserIdByQrCode($qrCode);
        log_message('debug', 'guardian: ' . json_encode($guardian));

        if (!$guardian) {
            return $this->failNotFound('Guardian QR code not found');
        }
        $userId = $guardian->user_id;

        $attendanceModel = new \App\Models\Attendance_Model();

        // Check if attendance already marked for the child on that date
        $existing = $attendanceModel->where('user_id', $userId)
            ->where('date', $data['date'])
            ->first();

        if ($existing) {
            return $this->fail('Attendance already marked for today');
        }

        $insertData = [
            'user_id' => $userId,
            'date' => $data['date'],
            'arrival_time' => $data['arrival_time'],
            'status' => $data['status'] ?? 'Present',
            'accompanied_by' => $qrCode,
            'leave_time' => '',  
            'picked_up_by' => '',
        ];

        if ($attendanceModel->insert($insertData)) {
            // Send email notification
            $email = \Config\Services::email();
            $userModel = new \App\Models\UserModel();
            $user = $userModel->find($userId);

            $emailSent = true;
            if ($user && !empty($user['email'])) {
                $email->setFrom('ecohaven28@gmail.com', 'Brightside');
                $email->setTo($user['email']);
                $email->setSubject('Child Arrival Notification');
                $email->setMessage("
                    <p>Dear Parent/Guardian,</p>
                    <p>This is to inform you that your child <strong>{$user['username']}</strong> has arrived at <strong>{$data['arrival_time']}</strong> on <strong>{$data['date']}</strong>.</p>
                    <p>Thank you.</p>
                ");

                if (!$email->send()) {
                    log_message('error', 'Email sending failed: ' . $email->printDebugger(['headers']));
                    $emailSent = false;
                }
            }
            return $this->respond(['success' => true, 'email_sent' => $emailSent]);
        } else {
            return $this->failServerError('Failed to save attendance');
        }
    }

