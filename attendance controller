            log_message('debug', 'User data: ' . print_r($user, true));

            if ($user && !empty($user['email'])) {
                $email = \Config\Services::email();

                $email->setFrom('ecohaven28@gmail.com', 'Brightside');
                $email->setTo($user['email']);
                $email->setSubject('Child Arrival Notification');

                $username = is_array($user['username']) ? '[Invalid Username]' : $user['username'];
                $leaveTime = is_array($data['leave_time']) ? '[Invalid Time]' : $data['leave_time'];
                $date = isset($data['date']['value']) ? $data['date']['value'] : '[Invalid Date]';

                $guardianName = isset($guardianDetails->full_name) ? $guardianDetails->full_name : 'Unknown';

                $message = "<html>
