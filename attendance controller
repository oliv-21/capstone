    public function markPickup()
    {
        if (!$this->request->isAJAX() || !$this->request->is('post')) {
            return $this->failForbidden('Invalid request');
        }

        $data = $this->request->getJSON(true);

        if (
            empty($data['user_id']) ||
            empty($data['leave_time']) ||
            empty($data['guardian_id']) ||
            empty($data['date'])
        ) {
            return $this->failValidationErrors('Missing required fields');
        }

        $attendanceModel = new \App\Models\Attendance_Model();

        $existing = $attendanceModel->where('user_id', $data['user_id'])
            ->where('date', $data['date'])
            ->first();

        if (!$existing) {
            return $this->failNotFound('Attendance record not found');
        }

        $updateData = [
            'leave_time' => $data['leave_time'],
            'picked_up_by' => $data['guardian_id'],
        ];

