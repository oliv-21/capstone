                    </li>
                </ul>

                <div class="bg-light p-3 rounded-2 border border-1 border-dark mb-3">
                    <p class="mb-1"><strong>Total Selected:</strong> ₱<span id="totalAmountTuition">0.00</span></p>
                    <label class="form-label mt-2"><strong>Enter Partial Payment:</strong></label>
                    <input type="number" class="form-control mb-2">
                    <p class="mb-0"><strong>Balance After Payment:</strong> ₱<span>0.00</span></p>
