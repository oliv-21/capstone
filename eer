namespace App\Models; // Adjust namespace as needed

use CodeIgniter\Model;

class ChatModel extends Model // Or whatever your model name is
{
    protected $table = 'message'; // Assuming this is your messages table
    protected $allowedFields = []; // Adjust as needed

    public function getContacts($userId, $role)
    {
        $db = \Config\Database::connect();

        // Parameterized subquery for latest message per contact pair
        // This groups by user pair and gets the MAX sent_at, then joins back for the actual message
        $subQuerySql = "
            SELECT 
                m1.user_a,
                m1.user_b,
                m1.message,
                m1.sent_at,
                m1.is_read,
                m1.sender_id,
                m1.receiver_id
            FROM (
                SELECT 
                    CASE WHEN sender_id < receiver_id THEN sender_id ELSE receiver_id END AS user_a,
                    CASE WHEN sender_id < receiver_id THEN receiver_id ELSE sender_id END AS user_b,
                    MAX(sent_at) AS max_sent_at
                FROM message
                WHERE sender_id = ? OR receiver_id = ?
                GROUP BY user_a, user_b
            ) latest
            INNER JOIN message m1 ON (
                (m1.sender_id = latest.user_a AND m1.receiver_id = latest.user_b) OR
                (m1.sender_id = latest.user_b AND m1.receiver_id = latest.user_a)
            ) AND m1.sent_at = latest.max_sent_at
            ORDER BY m1.sent_at DESC
        ";

        // Execute subquery with bindings to prevent injection
        $subQuery = $db->query($subQuerySql, [$userId, $userId]);

        // Main query using Query Builder
        $builder = $db->table('users u')
            ->select("
                u.id, 
                u.username, 
                sub.message AS last_message, 
                sub.sent_at,
                COALESCE(s.profile_pic, a.profilepic, t.profile_pic, 'default-avatar.png') AS profile_pic, -- Added default fallback
                COALESCE(
                    NULLIF(TRIM(CONCAT_WS(' ', s.first_name, s.last_name)), ''),
                    NULLIF(TRIM(CONCAT_WS(' ', a.firstname, a.lastname)), ''),
                    NULLIF(TRIM(CONCAT_WS(' ', t.first_name, t.last_name)), ''),
                    u.username -- Fallback to username if no name
                ) AS full_name,
                (
                    SELECT COUNT(*) 
                    FROM message m 
                    WHERE m.receiver_id = ? AND m.is_read = 0 
                    AND (
                        (m.sender_id = u.id) OR 
                        (CASE WHEN m.sender_id < m.receiver_id THEN m.sender_id ELSE m.receiver_id END = u.id)
                    )
                ) AS unread_count -- More accurate unread per contact
            ", false) // false to allow raw SQL in select
            ->joinSub($subQuery, 'sub', 
                "(sub.user_a = u.id AND sub.user_b = ?) OR (sub.user_b = u.id AND sub.user_a = ?)",
                'left') // Use joinSub for subquery join
            ->join('students s', 's.user_id = u.id', 'left')
            ->join('adminandstaff a', 'a.user_id = u.id', 'left')
            ->join('teachers t', 't.user_id = u.id', 'left')
            ->where('u.id !=', $userId)
            ->groupBy('u.id')
            ->orderBy('sub.sent_at', 'DESC');

        // Bind parameters for main query (userId repeated for unread subquery and joins)
        $builder->setBindData([$userId, $userId, $userId]); // For unread_count, join params

        // Role-based contact visibility (more explicit)
        $allowedRoles = [];
        if ($role === 'student') {
            $allowedRoles = ['teacher', 'admin'];
        } elseif ($role === 'admin') {
            $allowedRoles = ['teacher', 'student'];
        } elseif ($role === 'teacher') {
            $allowedRoles = ['student', 'admin'];
        }

        if (!empty($allowedRoles)) {
            $builder->whereIn('u.role', $allowedRoles);
        } else {
            // Default: No restriction if role invalid
            log_message('warning', 'Invalid role provided to getContacts: ' . $role);
        }

        // Optional: Add limit for performance (e.g., top 50 contacts)
        // $builder->limit(50);

        $result = $builder->get()->getResultArray();

        // Log for debugging (remove in production)
        log_message('info', 'Fetched ' . count($result) . ' contacts for user_id: ' . $userId . ', role: ' . $role);

        return $result;
    }
}

