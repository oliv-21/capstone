          Are you sure you want to proceed with this bulk payment?
        </div>
        <div class="modal-footer">
          <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button class="btn btn-success">Confirm & Pay</button>
        </div>
      </div>
    </div>
  </div>


<script>
document.addEventListener("DOMContentLoaded", function() {
    const paymentType = document.getElementById("paymentType");
    const miscCard = document.getElementById("miscCard");
    const tuitionCard = document.getElementById("tuitionCard");
    const noneCard = document.getElementById("none");
    const miscChildrenList = document.getElementById("miscChildrenList");

    // Function to update totals and balance
    function updateTotals() {
        let total = 0;
        const checkboxes = miscChildrenList.querySelectorAll('.child-checkbox');
        checkboxes.forEach(c => {
            if (c.checked) total += parseFloat(c.dataset.amount);
        });
        const totalMisc = document.getElementById('totalAmountMisc');
        if (totalMisc) totalMisc.textContent = total.toLocaleString();
        
        const partialInput = document.querySelector('input[name="partial_payment"]');
        const partial = partialInput ? parseFloat(partialInput.value) || 0 : 0;
        const balance = total - partial;
        const balanceMisc = document.getElementById('balanceMisc');
        if (balanceMisc) balanceMisc.textContent = balance.toLocaleString();
    }

    // Populate Miscellaneous children dynamically
    function populateMiscChildren(children) {
        miscChildrenList.innerHTML = ''; // Clear previous
        children.forEach(child => {
            const li = document.createElement('li');
            li.className = "list-group-item d-flex justify-content-between align-items-center";

            const div = document.createElement('div');
            div.innerHTML = `
                <input class="child-checkbox me-2" type="checkbox" name="children[]" value="${child.admission_id}" data-amount="${child.remaining_balance}">
                ${child.full_name} - Misc Fee (Paid: ₱${parseFloat(child.amount_paid).toLocaleString()}, Balance: ₱${parseFloat(child.remaining_balance).toLocaleString()})
            `;
            li.appendChild(div);

            const strong = document.createElement('strong');
            strong.textContent = `₱${parseFloat(child.remaining_balance).toLocaleString()}`;
            li.appendChild(strong);

            miscChildrenList.appendChild(li);
        });

        // Attach checkbox listeners
        const checkboxes = miscChildrenList.querySelectorAll('.child-checkbox');
        checkboxes.forEach(cb => {
            cb.addEventListener('change', updateTotals);
        });
    }

    // Handle payment type change
    function handlePaymentTypeChange() {
        const planId = paymentType.value;
        noneCard.style.display = "none"; // Hide placeholder initially

        // Toggle cards
        if (planId == 2) {
            miscCard.style.display = "block";
            tuitionCard.style.display = "none";

            // Fetch payment data for Miscellaneous
            fetch("<?= base_url('get-payments') ?>/" + planId + "/<?= esc($student->user_id) ?>")
                .then(res => res.json())
                .then(data => {
                    console.log("Received payment data:", data);
                    populateMiscChildren(data); // populate children dynamically
                })
                .catch(err => console.error("Error fetching payment data:", err));

        } else if (planId == 3) {
            miscCard.style.display = "none";
            tuitionCard.style.display = "block";
            // TODO: populate tuition dynamically if needed
        } else {
            miscCard.style.display = "none";
            tuitionCard.style.display = "none";
            noneCard.style.display = "block";
        }
    }

    paymentType.addEventListener("change", handlePaymentTypeChange);

    document.querySelectorAll('input[name="paymentMethod"]').forEach((elem) => {
        elem.addEventListener("change", function () {
            const details = document.getElementById("paymentDetails");
            details.innerHTML = ""; // clear previous content

            // Total and balance display
            const totalDiv = document.createElement("div");
            totalDiv.className = "bg-light p-3 rounded-2 border border-1 border-dark mb-3";
            totalDiv.innerHTML = `
                <p class="mb-1"><strong>Total Selected:</strong> ₱<span id="totalAmountMisc">0.00</span></p>
                <label class="form-label mt-2"><strong>Enter Partial Payment:</strong></label>
                <input type="number" name="partial_payment" class="form-control mb-2" placeholder="Enter amount">
                <p class="mb-0"><strong>Balance After Payment:</strong> ₱<span id="balanceMisc">0.00</span></p>
            `;
            details.appendChild(totalDiv);

            // Add listener to partial payment input
            const partialInput = totalDiv.querySelector('input[name="partial_payment"]');
            if (partialInput) partialInput.addEventListener('input', updateTotals);

            // Payment-specific fields
            let paymentFields = document.createElement("div");
            paymentFields.className = "mb-3";

            if (this.value === "gcash" || this.value === "paymaya") {
                paymentFields.innerHTML = `
                    <label class="form-label">Full Name (Gcash/PayMaya Owner)</label>
                    <input type="text" class="form-control" name="fullname" required>
                    <label class="form-label mt-2">Gcash/PayMaya Number</label>
                    <input type="text" class="form-control" name="number" required>
                    <label class="form-label mt-2">Email Address (for receipt)</label>
                    <input type="email" class="form-control" name="email" required>
                    <button type="submit" class="btn btn-success w-100 mt-3">Pay Now via PayMongo</button>
                `;
            } else if (this.value === "card") {
                paymentFields.innerHTML = `
                    <label class="form-label">Card Number</label>
                    <input type="text" class="form-control" name="cardNumber" required>
                    <label class="form-label mt-2">Expiry Month</label>
                    <input type="number" class="form-control" name="expiryMonth" placeholder="MM" min="1" max="12" required>
                    <label class="form-label mt-2">Expiry Year</label>
                    <input type="number" class="form-control" name="expiryYear" placeholder="YYYY" min="2025" max="2100" required>
                    <label class="form-label mt-2">CVV</label>
                    <input type="text" class="form-control" name="cvv" required>
                    <label class="form-label mt-2">Full Name</label>
                    <input type="text" class="form-control" name="fullname">
                    <label class="form-label mt-2">Email Address (for receipt)</label>
                    <input type="email" class="form-control" name="email">
                    <button type="submit" class="btn btn-success w-100 mt-3">Pay Now via Card</button>
                `;
            } else if (this.value === "dob") {
                paymentFields.innerHTML = `
                    <label class="form-label">Select Bank</label>
                    <select class="form-select" name="accountName" required>
                        <option value="">-- Select Bank --</option>
                        <option value="test_bank_one">BPI (Test)</option>
                        <option value="test_bank_two">UnionBank (Test)</option>
                        <option value="bdo">BDO</option>
                        <option value="metrobank">Metrobank</option>
                        <option value="landbank">Landbank</option>
                    </select>
                    <label class="form-label mt-2">Full Name</label>
                    <input type="text" class="form-control" name="fullname">
                    <label class="form-label mt-2">Email Address (for receipt)</label>
                    <input type="email" class="form-control" name="email">
                    <button type="submit" class="btn btn-success w-100 mt-3">Pay Now via DOB</button>
                `;
            }

            details.appendChild(paymentFields);
            details.style.display = "block";
        });
    });
});
</script>


</body>
</html>





















