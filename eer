<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Generate Report — Brightside</title>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
  <style>
    :root{--bg:#f6f8fb;--card:#fff;--muted:#6b7280;--accent:#2563eb}
    body{font-family:Inter,ui-sans-serif,system-ui,Segoe UI,Roboto,"Helvetica Neue",Arial; background:var(--bg); margin:0; color:#111}
    .container{max-width:1100px;margin:28px auto;padding:20px}
    .card{background:var(--card);border-radius:10px;padding:18px;box-shadow:0 6px 18px rgba(15,23,42,0.06)}
    h1{font-size:20px;margin:0 0 8px}
    .controls{display:flex;gap:10px;flex-wrap:wrap;margin:12px 0 18px}
    .controls input, .controls select, .controls button{padding:8px 10px;border-radius:8px;border:1px solid #e6e9ef;background:#fff}
    .controls .spacer{flex:1}
    table{width:100%;border-collapse:collapse;margin-top:8px}
    th,td{padding:10px 12px;border-bottom:1px solid #eef2f7;text-align:left;font-size:14px}
    th{background:#fbfdff;font-weight:600;color:#374151}
    td.center{text-align:center}
    .badge{display:inline-block;padding:6px 8px;border-radius:999px;font-size:12px}
    .badge.enrolled{background:#ecfdf5;color:#065f46}
    .badge.pending{background:#fff7ed;color:#92400e}
    .summary{display:flex;gap:12px;margin-top:12px}
    .summary .item{background:#f8fafc;padding:10px;border-radius:8px;min-width:140px}
    @media print{.controls, .no-print{display:none} body{background:#fff} .container{max-width:100%;margin:0;padding:0}}
  </style>
</head>
<body>
  <div class="container">
    <div class="card">
      <div style="display:flex;align-items:center;gap:12px;">
        <i class="fa-solid fa-file-invoice-dollar" style="font-size:22px;color:var(--accent)"></i>
        <div>
          <h1>Generate Report</h1>
          <div style="color:var(--muted);font-size:13px">Payments & guardians report — filter by date, status, or guardian</div>
        </div>
        <div class="spacer"></div>
        <button class="no-print" onclick="window.print()" title="Print"><i class="fa-solid fa-print"></i> Print</button>
      </div>

      <div class="controls">
        <label>From <input type="date" id="fromDate"></label>
        <label>To <input type="date" id="toDate"></label>
        <label>Status
          <select id="statusFilter">
            <option value="">All</option>
            <option value="Enrolled">Enrolled</option>
            <option value="Pending">Pending</option>
          </select>
        </label>
        <input type="text" id="q" placeholder="Search guardian or child..." style="min-width:200px">
        <div class="spacer"></div>
        <button onclick="applyFilters()">Apply</button>
        <button onclick="resetFilters()">Reset</button>
        <button onclick="exportCSV()" class="no-print"><i class="fa-solid fa-file-csv"></i> Export CSV</button>
      </div>

      <div class="summary">
        <div class="item"><strong>Total Guardians</strong><div id="totalGuardians">0</div></div>
        <div class="item"><strong>Total Students</strong><div id="totalStudents">0</div></div>
        <div class="item"><strong>Total Collected</strong><div id="totalCollected">₱0.00</div></div>
      </div>

      <div style="overflow:auto;margin-top:12px">
        <table id="reportTable">
          <thead>
            <tr>
              <th>Guardian</th>
              <th>Contact</th>
              <th>Address</th>
              <th>Students</th>
              <th class="center">Total Paid</th>
              <th class="center">Remaining</th>
              <th class="center">Status</th>
            </tr>
          </thead>
          <tbody>
            <tr data-status="Enrolled">
              <td>Roldan Araneta Oliveros</td>
              <td>09205804090<br><small>roldanoliveros0621@gmail.com</small></td>
              <td>Nagcarlan, Buboy, Poblacion</td>
              <td><ul><li>Juan Oliveros (Admission ID: 1023)</li></ul></td>
              <td class="center">₱12,500.00</td>
              <td class="center">₱0.00</td>
              <td class="center"><span class="badge enrolled">Enrolled</span></td>
            </tr>
            <tr data-status="Pending">
              <td>Maria Cruz</td>
              <td>09171234567<br><small>maria@example.com</small></td>
              <td>Calamba, San Roque, Brgy 1</td>
              <td><ul><li>Anna Cruz (Admission ID: 1035)</li><li>Ben Cruz (Admission ID: 1040)</li></ul></td>
              <td class="center">₱8,000.00</td>
              <td class="center">₱4,000.00</td>
              <td class="center"><span class="badge pending">Pending</span></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <script>
    function currency(val){ return '₱' + Number(val).toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}); }

    function updateSummary(){
      const rows = Array.from(document.querySelectorAll('#reportTable tbody tr')).filter(r => r.style.display !== 'none');
      document.getElementById('totalGuardians').textContent = rows.length;
      let students = 0, totalCollected = 0;
      rows.forEach(r=>{
        students += r.querySelectorAll('td:nth-child(4) li').length;
        totalCollected += parseFloat(r.querySelector('td:nth-child(5)').textContent.replace(/[₱,]/g,''));
      });
      document.getElementById('totalStudents').textContent = students;
      document.getElementById('totalCollected').textContent = currency(totalCollected);
    }

    function applyFilters(){
      const q = document.getElementById('q').value.toLowerCase();
      const status = document.getElementById('statusFilter').value;
      document.querySelectorAll('#reportTable tbody tr').forEach(row=>{
        const matchStatus = !status || row.dataset.status === status;
        const matchQuery = !q || row.textContent.toLowerCase().includes(q);
        row.style.display = matchStatus && matchQuery ? '' : 'none';
      });
      updateSummary();
    }

    function resetFilters(){
      document.getElementById('fromDate').value='';
      document.getElementById('toDate').value='';
      document.getElementById('statusFilter').value='';
      document.getElementById('q').value='';
      applyFilters();
    }

    function exportCSV(){
      const rows = Array.from(document.querySelectorAll('#reportTable tbody tr')).filter(r => r.style.display !== 'none');
      const cols = ['Guardian','Contact','Address','Students','Total Paid','Remaining','Status'];
      const data = [cols.join(',')];
      rows.forEach(r=>{
        const tds = r.querySelectorAll('td');
        data.push([...tds].map(td=>`"${td.textContent.trim().replace(/"/g,'""')}"`).join(','));
      });
      const blob = new Blob([data.join('\n')],{type:'text/csv'});
      const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = 'report.csv'; a.click();
    }

    document.addEventListener('DOMContentLoaded', updateSummary);
  </script>
</body>
</html>


