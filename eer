  <script>
    $(document).ready(function () {
      var table = $('#membersTable').DataTable();

      // Filter functionality
      $.fn.dataTable.ext.search.push(function (settings, data) {
        let selectedClass = $('#filterClass').val();
        let selectedStatus = $('#filterStatus').val();
        let className = data[1].trim();
        let status = data[2].trim().toLowerCase();

        if ((selectedClass === 'all' || !selectedClass || className === selectedClass) &&
          (selectedStatus === 'all' || !selectedStatus || status === selectedStatus)) {
          return true;
        }
        return false;
      });

      $('#filterClass, #filterStatus').on('change', function () {
        table.draw();
      });

      // Open modal and populate student info
      $(document).on('click', '.viewPaymentBtn', function () {
        let studentId = $(this).data('userId');
        $('#student_id').val(studentId);
        $('#summaryStudentName').text($(this).data('name'));
        $('#summaryClass').text($(this).data('class'));
        $('#dueDate').text($(this).data('paymentdue'));
        $('#amountField').val('');
        $('#paymentType').val('');

        // Load payment history via AJAX (dummy example)
        let history = [
          { payment_date: '2025-05-01', method: 'Cash', month: 'July', amount_paid: '2500', status: 'Paid' }
        ];
        let tbody = $('#paymentHistoryTable').empty();
        if (history.length > 0) {
          history.forEach(p => {
            let statusBadge = p.status.toLowerCase() === 'paid' ? '<span class="badge bg-success">Paid</span>' : '<span class="badge bg-warning text-dark">Pending</span>';
            tbody.append(`<tr>
              <td>${p.payment_date}</td>
              <td>${p.method}</td>
              <td>${p.month}</td>
              <td>₱${p.amount_paid}</td>
              <td>${statusBadge}</td>
            </tr>`);
          });
        } else {
          tbody.append('<tr><td colspan="5" class="text-center">No payment history found</td></tr>');
        }

        $('#paymentModal').modal('show');
      });

      // Payment type logic
      $('#paymentType').on('change', function () {
        let type = $(this).val();
        if (type === 'tuition') {
          $('#amountField').val('2500').prop('readOnly', true);
        } else if (type === 'full') {
          $('#amountField').val('33000').prop('readOnly', true);
        } else if (type === 'remaining') {
          let remaining = $('#membersTable').find(`button[data-user-id='${$('#student_id').val()}']`).data('remainingfee');
          $('#amountField').val(remaining).prop('readOnly', true);
        } else {
          $('#amountField').val('').prop('readOnly', false);
        }
      });

      // Save payment
      $('#savePaymentBtn').on('click', function () {
        Swal.fire({
          title: 'Confirm Payment?',
          text: 'Do you want to save this payment?',
          icon: 'question',
          showCancelButton: true,
          confirmButtonText: 'Yes, save it!',
          cancelButtonText: 'Cancel'
        }).then((result) => {
          if (result.isConfirmed) {
            $('#cashPaymentForm').submit();
          }
        });
      });
    });
  </script>
</body>
